# Copy to .env for local development, or set these in Render / Railway / Fly.io.

# Neon: Project → Connection details → copy the connection string.
# Use the pooled host (*-pooler.*.neon.tech) for web apps when available.
# Example:
# CERTCHAIN_DATABASE_URL=postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require

CERTCHAIN_DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Public URL of the deployed backend (used in PDF QR codes). Example:
# CERTCHAIN_PUBLIC_BASE_URL=https://certchain-api.onrender.com
